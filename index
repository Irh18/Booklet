<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PDF Booklet Maker</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
    background:#f8f9fa;
}
.card{
    max-width:600px;
    margin:auto;
    margin-top:50px;
}
</style>
</head>
<body>

<div class="container">
    <div class="card shadow">
        <div class="card-body">
            <h3 class="text-center mb-4">
                PDF Booklet Maker
            </h3>

            <input type="file" id="pdfFile" accept=".pdf" class="form-control mb-3">

            <button class="btn btn-primary w-100" onclick="createBooklet()">
                Buat Booklet
            </button>

            <div id="status" class="mt-3 text-center"></div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/pdf-lib"></script>

<script>

async function createBooklet(){

    const fileInput = document.getElementById('pdfFile');

    if(!fileInput.files.length){
        alert('Pilih PDF terlebih dahulu');
        return;
    }

    document.getElementById('status').innerHTML='Memproses PDF...';

    const file = fileInput.files[0];
    const bytes = await file.arrayBuffer();

    const srcPdf = await PDFLib.PDFDocument.load(bytes);
    const totalPages = srcPdf.getPageCount();

    let pages = [];

    for(let i=0;i<totalPages;i++){
        pages.push(i);
    }

    while(pages.length % 4 !== 0){
        pages.push(null);
    }

    const bookletOrder = [];

    let left = 0;
    let right = pages.length - 1;

    while(left < right){

        bookletOrder.push(
            pages[right],
            pages[left]
        );

        bookletOrder.push(
            pages[left+1],
            pages[right-1]
        );

        left += 2;
        right -= 2;
    }

    const outputPdf = await PDFLib.PDFDocument.create();

    const A4_WIDTH = 842;
    const A4_HEIGHT = 595;

    for(let i=0;i<bookletOrder.length;i+=2){

        const sheet = outputPdf.addPage([A4_WIDTH,A4_HEIGHT]);

        const leftPage = bookletOrder[i];
        const rightPage = bookletOrder[i+1];

        if(leftPage !== null){

            const [embedded] = await outputPdf.embedPages([
                (await outputPdf.copyPages(srcPdf,[leftPage]))[0]
            ]);

            sheet.drawPage(embedded,{
                x:0,
                y:0,
                width:A4_WIDTH/2,
                height:A4_HEIGHT
            });
        }

        if(rightPage !== null){

            const [embedded] = await outputPdf.embedPages([
                (await outputPdf.copyPages(srcPdf,[rightPage]))[0]
            ]);

            sheet.drawPage(embedded,{
                x:A4_WIDTH/2,
                y:0,
                width:A4_WIDTH/2,
                height:A4_HEIGHT
            });
        }
    }

    const pdfBytes = await outputPdf.save();

    const blob = new Blob(
        [pdfBytes],
        {type:'application/pdf'}
    );

    const url = URL.createObjectURL(blob);

    const a = document.createElement('a');
    a.href = url;
    a.download = 'booklet.pdf';
    a.click();

    document.getElementById('status').innerHTML=
    '<span class="text-success">Booklet berhasil dibuat.</span>';
}

</script>

</body>
</html>
